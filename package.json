{
  "name": "checkers-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build:types": "npm run build --workspace=packages/types",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:engine": "npm run build --workspace=packages/engine",
    "build:ai": "npm run build --workspace=packages/ai",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build": "npm run build:types && npm run build:shared && npm run build:engine && npm run build:ai && npm run build:api && npm run build:web",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  }
}
